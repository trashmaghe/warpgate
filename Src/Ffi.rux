@[Import(lib: "winhttp")]
extern func WinHttpReceiveResponse(req: int, reserved: *opaque) -> bool;

@[Import(lib: "winhttp")]
extern func WinHttpReadData(req: int, buf: *char8,
                             to_read: uint32, bytes_read: *uint32) -> bool;

@[Import(lib: "winhttp")]
extern func WinHttpQueryDataAvailable(req: int, bytes_avail: *uint32) -> bool;

@[Import(lib: "winhttp")]
extern func WinHttpCloseHandle(handle: int) -> bool;

