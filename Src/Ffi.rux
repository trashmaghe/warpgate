// Warpgate — FFI declarations and compile-time constants

// ── Winsock2 ──────────────────────────────────────────────────────────────────

@[Import(lib: "ws2_32")]
extern func WSAStartup(version: uint16, data: *opaque) -> int;

@[Import(lib: "ws2_32")]
extern func WSACleanup() -> int;

@[Import(lib: "ws2_32")]
extern func socket(af: int, sock_type: int, protocol: int) -> int;

// WSASocket with flags (e.g. WSA_FLAG_OVERLAPPED for IOCP)
@[Import(lib: "ws2_32")]
extern func WSASocket(af: int, sock_type: int, protocol: int,
                      proto_info: *opaque, group: uint32, flags: uint32) -> int;

@[Import(lib: "ws2_32")]
extern func bind(sock: int, addr: *opaque, addrlen: int) -> int;

@[Import(lib: "ws2_32")]
extern func listen(sock: int, backlog: int) -> int;

@[Import(lib: "ws2_32")]
extern func accept(sock: int, addr: *opaque, addrlen: *int) -> int;

@[Import(lib: "ws2_32")]
extern func connect(sock: int, addr: *opaque, addrlen: int) -> int;

@[Import(lib: "ws2_32")]
extern func recv(sock: int, buf: *char8, len: int, flags: int) -> int;

@[Import(lib: "ws2_32")]
extern func send(sock: int, buf: *char8, len: int, flags: int) -> int;

@[Import(lib: "ws2_32")]
extern func closesocket(sock: int) -> int;

@[Import(lib: "ws2_32")]
extern func setsockopt(sock: int, level: int, optname: int,
                       optval: *char8, optlen: int) -> int;

@[Import(lib: "ws2_32")]
extern func inet_addr(cp: *char8) -> uint32;

@[Import(lib: "ws2_32")]
extern func getaddrinfo(node: *char8, service: *char8,
                        hints: *opaque, result: *opaque) -> int;

@[Import(lib: "ws2_32")]
extern func freeaddrinfo(ai: *opaque);

// Overlapped I/O
@[Import(lib: "ws2_32")]
extern func WSARecv(sock: int, buffers: *opaque, buf_count: uint32,
                    bytes_recv: *uint32, flags: *uint32,
                    overlapped: *opaque, completion: *opaque) -> int;

@[Import(lib: "ws2_32")]
extern func WSASend(sock: int, buffers: *opaque, buf_count: uint32,
                    bytes_sent: *uint32, flags: uint32,
                    overlapped: *opaque, completion: *opaque) -> int;

@[Import(lib: "ws2_32")]
extern func WSAGetLastError() -> int;

// select for readiness polling (e.g. WebSocket bidirectional relay)
@[Import(lib: "ws2_32")]
extern func select(nfds: int, readfds: *opaque, writefds: *opaque,
                   exceptfds: *opaque, timeout: *opaque) -> int;

// ioctlsocket — set socket mode (e.g. FIONBIO for non-blocking)
@[Import(lib: "ws2_32")]
extern func ioctlsocket(sock: int, cmd: int, argp: *uint32) -> int;

// ── Mswsock — AcceptEx ────────────────────────────────────────────────────────

@[Import(lib: "mswsock")]
extern func AcceptEx(listen_sock: int, accept_sock: int,
                     output_buf: *char8, recv_data_len: uint32,
                     local_addr_len: uint32, remote_addr_len: uint32,
                     bytes_recv: *uint32, overlapped: *opaque) -> bool;

@[Import(lib: "mswsock")]
extern func GetAcceptExSockaddrs(output_buf: *char8, recv_data_len: uint32,
                                  local_addr_len: uint32, remote_addr_len: uint32,
                                  local_sockaddr: *opaque, local_len: *int,
                                  remote_sockaddr: *opaque, remote_len: *int);

// ── Kernel32 — I/O ────────────────────────────────────────────────────────────

@[Import(lib: "kernel32")]
extern func GetStdHandle(nStdHandle: int) -> int;

@[Import(lib: "kernel32")]
extern func WriteFile(handle: int, buf: *char8, count: uint64,
                      written: *uint64, overlapped: int) -> bool;

@[Import(lib: "kernel32")]
extern func CreateFileA(path: *char8, access: uint32, share: uint32,
                        security: *opaque, disposition: uint32,
                        flags: uint32, templ: int) -> int;

@[Import(lib: "kernel32")]
extern func ReadFile(handle: int, buf: *char8, to_read: uint32,
                     bytes_read: *uint32, overlapped: *opaque) -> bool;

@[Import(lib: "kernel32")]
extern func GetFileSizeEx(handle: int, size: *int64) -> bool;

@[Import(lib: "kernel32")]
extern func GetFileTime(handle: int, created: *opaque,
                        accessed: *opaque, written: *opaque) -> bool;

@[Import(lib: "kernel32")]
extern func CloseHandle(handle: int) -> bool;

@[Import(lib: "kernel32")]
extern func GetLastError() -> uint32;

// ── Kernel32 — IOCP ───────────────────────────────────────────────────────────

// Pass INVALID_HANDLE_VALUE / 0 as existing_port to create a new IOCP.
@[Import(lib: "kernel32")]
extern func CreateIoCompletionPort(handle: int, existing_port: int,
                                    completion_key: int, num_threads: uint32) -> int;

// lpOverlapped receives a pointer to the OVERLAPPED that completed.
@[Import(lib: "kernel32")]
extern func GetQueuedCompletionStatus(port: int, bytes: *uint32, key: *int,
                                       overlapped: *opaque, timeout: uint32) -> bool;

@[Import(lib: "kernel32")]
extern func PostQueuedCompletionStatus(port: int, bytes: uint32, key: int,
                                        overlapped: *opaque) -> bool;

// ── Kernel32 — Memory ─────────────────────────────────────────────────────────

@[Import(lib: "kernel32")]
extern func GetProcessHeap() -> int;

@[Import(lib: "kernel32")]
extern func HeapAlloc(heap: int, flags: uint32, bytes: uint64) -> *opaque;

@[Import(lib: "kernel32")]
extern func HeapFree(heap: int, flags: uint32, ptr: *opaque) -> bool;

// ── Kernel32 — Threading ──────────────────────────────────────────────────────

@[Import(lib: "kernel32")]
extern func CreateThread(security: *opaque, stack_size: uint64,
                         start: *opaque, param: *opaque,
                         flags: uint32, id: *uint32) -> int;

@[Import(lib: "kernel32")]
extern func Sleep(ms: uint32);

@[Import(lib: "kernel32")]
extern func InitializeCriticalSection(cs: *opaque);

@[Import(lib: "kernel32")]
extern func DeleteCriticalSection(cs: *opaque);

@[Import(lib: "kernel32")]
extern func EnterCriticalSection(cs: *opaque);

@[Import(lib: "kernel32")]
extern func LeaveCriticalSection(cs: *opaque);

@[Import(lib: "kernel32")]
extern func CreateSemaphoreA(security: *opaque, initial: int,
                              maximum: int, name: *char8) -> int;

@[Import(lib: "kernel32")]
extern func ReleaseSemaphore(sem: int, count: int, prev: *int) -> bool;

@[Import(lib: "kernel32")]
extern func WaitForSingleObject(handle: int, ms: uint32) -> uint32;

@[Import(lib: "kernel32")]
extern func InterlockedAdd64(addend: *opaque, value: int) -> int;

// ── Kernel32 — Time ───────────────────────────────────────────────────────────

// GetTickCount64 — milliseconds since system boot (for rate limiting)
@[Import(lib: "kernel32")]
extern func GetTickCount64() -> int;

// GetSystemTimeAsFileTime — FILETIME (100-ns intervals since 1601-01-01) for JWT exp
@[Import(lib: "kernel32")]
extern func GetSystemTimeAsFileTime(systime: *opaque);

@[Import(lib: "kernel32")]
extern func GetLocalTime(st: *opaque);

@[Import(lib: "kernel32")]
extern func QueryPerformanceCounter(count: *opaque) -> bool;

@[Import(lib: "kernel32")]
extern func QueryPerformanceFrequency(freq: *opaque) -> bool;

// ── Kernel32 — Process ────────────────────────────────────────────────────────

@[Import(lib: "kernel32")]
extern func ExitProcess(code: uint32);

@[Import(lib: "kernel32")]
extern func SetConsoleCtrlHandler(handler: *opaque, add: bool) -> bool;

// Environment variable access — used to publish the control block address to CtrlHandler
@[Import(lib: "kernel32")]
extern func SetEnvironmentVariableA(name: *char8, value: *char8) -> bool;

@[Import(lib: "kernel32")]
extern func GetEnvironmentVariableA(name: *char8, buf: *char8,
                                     size: uint32, written: *uint32) -> uint32;

// ── HTTP.sys (httpapi.dll) ────────────────────────────────────────────────────

// Version passed as uint32: low USHORT = major, high USHORT = minor.
// HTTP API v2.0 = 0x00000002
@[Import(lib: "httpapi")]
extern func HttpInitialize(version: uint32, flags: uint32,
                           reserved: *opaque) -> uint32;

@[Import(lib: "httpapi")]
extern func HttpTerminate(flags: uint32, reserved: *opaque) -> uint32;

// Name and SecurityAttributes may be null (0).
@[Import(lib: "httpapi")]
extern func HttpCreateRequestQueue(version: uint32, name: *opaque,
                                    security: *opaque, flags: uint32,
                                    handle: *int) -> uint32;

@[Import(lib: "httpapi")]
extern func HttpCloseRequestQueue(handle: int) -> uint32;

// FullyQualifiedUrl is a wide (UTF-16) string.
@[Import(lib: "httpapi")]
extern func HttpAddUrl(handle: int, url: *char8,
                       reserved: *opaque) -> uint32;

@[Import(lib: "httpapi")]
extern func HttpRemoveUrl(handle: int, url: *char8) -> uint32;

// Blocking receive — fills pRequestBuffer.
@[Import(lib: "httpapi")]
extern func HttpReceiveHttpRequest(handle: int, request_id: int,
                                    flags: uint32, buf: *char8,
                                    buf_len: uint32, bytes_recv: *uint32,
                                    overlapped: *opaque) -> uint32;

// pResponse is *HTTP_RESPONSE — passed as *opaque.
@[Import(lib: "httpapi")]
extern func HttpSendHttpResponse(handle: int, request_id: int,
                                  flags: uint32, response: *opaque,
                                  cache: *opaque, bytes_sent: *uint32,
                                  reserved1: *opaque, reserved2: uint32,
                                  overlapped: *opaque,
                                  log_data: *opaque) -> uint32;

// ── Zlib (zlib1.dll) ──────────────────────────────────────────────────────────

// Macro-expanded name; pass ZLIB_VERSION string + sizeof(z_stream).
@[Import(lib: "zlib1")]
extern func deflateInit2_(strm: *opaque, level: int, method: int,
                          window_bits: int, mem_level: int, strategy: int,
                          version: *char8, stream_size: int) -> int;

@[Import(lib: "zlib1")]
extern func deflate(strm: *opaque, flush: int) -> int;

@[Import(lib: "zlib1")]
extern func deflateEnd(strm: *opaque) -> int;

@[Import(lib: "zlib1")]
extern func inflateInit_(strm: *opaque, version: *char8,
                         stream_size: int) -> int;

@[Import(lib: "zlib1")]
extern func inflate(strm: *opaque, flush: int) -> int;

@[Import(lib: "zlib1")]
extern func inflateEnd(strm: *opaque) -> int;

// ── BCrypt (bcrypt.dll) ───────────────────────────────────────────────────────

// pszAlgId and pszImplementation are wide strings (*char8 = UTF-16LE buffer).
@[Import(lib: "bcrypt")]
extern func BCryptOpenAlgorithmProvider(ph_alg: *int, psz_alg_id: *char8,
                                         psz_impl: *char8, flags: uint32) -> int;

@[Import(lib: "bcrypt")]
extern func BCryptCloseAlgorithmProvider(h_alg: int, flags: uint32) -> int;

@[Import(lib: "bcrypt")]
extern func BCryptGetProperty(h_obj: int, psz_prop: *char8,
                               pb_out: *char8, cb_out: uint32,
                               pcb_result: *uint32, flags: uint32) -> int;

@[Import(lib: "bcrypt")]
extern func BCryptCreateHash(h_alg: int, ph_hash: *int,
                              pb_hash_obj: *char8, cb_hash_obj: uint32,
                              pb_secret: *char8, cb_secret: uint32,
                              flags: uint32) -> int;

@[Import(lib: "bcrypt")]
extern func BCryptHashData(h_hash: int, pb_input: *char8,
                            cb_input: uint32, flags: uint32) -> int;

@[Import(lib: "bcrypt")]
extern func BCryptFinishHash(h_hash: int, pb_output: *char8,
                              cb_output: uint32, flags: uint32) -> int;

@[Import(lib: "bcrypt")]
extern func BCryptDestroyHash(h_hash: int) -> int;

