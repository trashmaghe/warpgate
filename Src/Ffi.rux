// ── Secur32 — SChannel ───────────────────────────────────────────────────────

@[Import(lib: "secur32")]
extern func AcquireCredentialsHandleA(
    principal: *char8, package: *char8, cred_use: uint32,
    logon_id: *opaque, auth_data: *opaque,
    get_key_fn: *opaque, get_key_arg: *opaque,
    cred_handle: *opaque, expiry: *opaque) -> int;

@[Import(lib: "secur32")]
extern func InitializeSecurityContextA(
    cred: *opaque, ctx: *opaque, target: *char8,
    flags: uint32, reserved1: uint32, data_rep: uint32,
    input: *opaque, reserved2: uint32,
    new_ctx: *opaque, output: *opaque,
    attrs: *uint32, expiry: *opaque) -> int;

@[Import(lib: "secur32")]
extern func DeleteSecurityContext(ctx: *opaque) -> int;

@[Import(lib: "secur32")]
extern func FreeCredentialsHandle(cred: *opaque) -> int;

@[Import(lib: "secur32")]
extern func EncryptMessage(ctx: *opaque, qop: uint32,
                           msg: *opaque, seq: uint32) -> int;

@[Import(lib: "secur32")]
extern func DecryptMessage(ctx: *opaque, msg: *opaque,
                           seq: uint32, qop: *uint32) -> int;

@[Import(lib: "secur32")]
extern func QueryContextAttributesA(ctx: *opaque, attr: uint32,
                                    buf: *opaque) -> int;

@[Import(lib: "secur32")]
extern func FreeContextBuffer(buf: *opaque) -> int;

// Server-side SChannel handshake
@[Import(lib: "secur32")]
extern func AcceptSecurityContext(
    cred: *opaque, ctx: *opaque, input: *opaque,
    flags: uint32, data_rep: uint32,
    new_ctx: *opaque, output: *opaque,
    attrs: *uint32, expiry: *opaque) -> int;

// ── Crypt32 — PKCS#12 certificate import ─────────────────────────────────────

// pfx is a pointer to a CRYPT_DATA_BLOB { DWORD cbData; BYTE *pbData; } = 16 bytes on x64.
// password is a UTF-16LE null-terminated wide string.
@[Import(lib: "crypt32")]
extern func PFXImportCertStore(pfx: *opaque, password: *char8,
                                flags: uint32) -> int;

// Find the first certificate in the store (CERT_FIND_ANY = 0).
@[Import(lib: "crypt32")]
extern func CertFindCertificateInStore(
    cert_store: int, encoding: uint32,
    find_flags: uint32, find_type: uint32,
    find_para: *opaque, prev_cert: *opaque) -> *opaque;

@[Import(lib: "crypt32")]
extern func CertCloseStore(cert_store: int, flags: uint32) -> bool;

@[Import(lib: "crypt32")]
extern func CertFreeCertificateContext(cert_context: *opaque) -> bool;

// ── Network structures ────────────────────────────────────────────────────────

struct SockAddrIn {
    sin_family: uint16,
    sin_port:   uint16,
    sin_addr:   uint32,
    sin_zero:   [uint8; 8],
}

// ── Socket constants ──────────────────────────────────────────────────────────

const AF_INET: int                   = 2;
const SOCK_STREAM: int               = 1;
const IPPROTO_TCP: int               = 6;
const INVALID_SOCKET: int            = -1;
const SOL_SOCKET: int                = 0xFFFF;
const SO_RCVTIMEO: int               = 0x1006;
const SO_SNDTIMEO: int               = 0x1005;
const SO_REUSEADDR: int              = 0x0004;
const SO_UPDATE_ACCEPT_CONTEXT: int  = 0x700B;
const INADDR_NONE: uint32            = 0xFFFFFFFF;
const WSA_FLAG_OVERLAPPED: uint32    = 1;
const WSA_IO_PENDING: int            = 997;

// ── Sync / process constants ──────────────────────────────────────────────────

const INFINITE: uint32          = 0xFFFFFFFF;
const WAIT_OBJECT_0: uint32     = 0;
const CTRL_C_EVENT: uint32      = 0;
const CTRL_CLOSE_EVENT: uint32  = 2;

// ── Memory constants ──────────────────────────────────────────────────────────

const HEAP_ZERO_MEMORY: uint32  = 8;

// ── File constants ────────────────────────────────────────────────────────────

const GENERIC_READ: uint32          = 0x80000000;
const GENERIC_WRITE: uint32         = 0x40000000;
const FILE_SHARE_READ: uint32       = 1;
const FILE_SHARE_WRITE: uint32      = 2;
const FILE_SHARE_RW: uint32         = 3;
const OPEN_EXISTING: uint32         = 3;
const OPEN_ALWAYS: uint32           = 4;   // create if missing, open if present
const FILE_ATTRIBUTE_NORMAL: uint32 = 0x80;
const FILE_APPEND_DATA: uint32      = 0x00000004;
const INVALID_HANDLE_VALUE: int     = -1;

// SECPKG_ATTR_APPLICATION_PROTOCOL (ALPN negotiation result)
const SECPKG_ATTR_APPLICATION_PROTOCOL: uint32 = 35;

// ── SChannel constants ────────────────────────────────────────────────────────

const SECPKG_CRED_OUTBOUND: uint32     = 2;
const SECURITY_NATIVE_DREP: uint32     = 0x10;
const SEC_E_OK: int                    = 0;
const SEC_I_CONTINUE_NEEDED: int       = 0x00090312;
const SEC_I_INCOMPLETE_CREDS: int      = 0x00090320;
const SEC_E_INCOMPLETE_MESSAGE: uint32 = 0x80090318;
const ISC_REQ_FLAGS: uint32            = 0x0000C11C;
const SCHANNEL_CRED_VERSION: uint32    = 4;
const SECBUFFER_VERSION: uint32        = 0;
const SECBUFFER_EMPTY: uint32          = 0;
const SECBUFFER_DATA: uint32           = 1;
const SECBUFFER_TOKEN: uint32          = 2;
const SECBUFFER_EXTRA: uint32          = 5;
const SECBUFFER_STREAM_TRAILER: uint32 = 6;
const SECBUFFER_STREAM_HEADER: uint32  = 7;
const SECPKG_ATTR_STREAM_SIZES: uint32 = 4;

// ── HTTP.sys constants ────────────────────────────────────────────────────────

const HTTPAPI_VERSION_2: uint32         = 0x00000002;
const HTTP_INITIALIZE_SERVER: uint32    = 1;
const HTTP_VERB_GET: int                = 4;
const HTTP_VERB_HEAD: int               = 5;
const HTTP_VERB_POST: int               = 6;
const HTTP_VERB_PUT: int                = 7;
const HTTP_VERB_DELETE: int             = 8;
const HTTP_VERB_OPTIONS: int            = 3;
const HTTP_VERB_PATCH: int              = 19;
// HTTP_REQUEST field offsets (Win64, HTTP_REQUEST_V1)
const HTTPREQ_OFF_REQUEST_ID: int       = 16;
const HTTPREQ_OFF_VERB: int             = 36;
const HTTPREQ_OFF_RAW_URL_LEN: int      = 42;  // USHORT
const HTTPREQ_OFF_P_RAW_URL: int        = 56;  // ptr
const HTTPREQ_OFF_ABSPATH_LEN: int      = 68;  // USHORT (in CookedUrl)
const HTTPREQ_OFF_P_ABSPATH: int        = 88;  // ptr (in CookedUrl, wide)
const HTTPREQ_OFF_REMOTE_ADDR: int      = 104; // ptr to SOCKADDR
// HTTP_RESPONSE field offsets
const HTTPRESP_OFF_STATUS_CODE: int     = 8;
const HTTPRESP_OFF_REASON_LEN: int      = 10;
const HTTPRESP_OFF_P_REASON: int        = 16;  // ptr
const HTTPRESP_OFF_HEADERS: int         = 24;
const HTTPRESP_OFF_CHUNK_COUNT: int     = 536;
const HTTPRESP_OFF_P_CHUNKS: int        = 544;
// HTTP_DATA_CHUNK FromMemory offsets (DataChunkType=0)
const HTTPCHUNK_OFF_TYPE: int           = 0;
const HTTPCHUNK_OFF_P_BUFFER: int       = 8;
const HTTPCHUNK_OFF_BUFFER_LEN: int     = 16;
const HTTPCHUNK_SIZE: int               = 24;
// HTTP_RESPONSE total size (padded)
const HTTPRESP_SIZE: int                = 560;
const HTTP_KNOWN_HDR_CONTENT_TYPE: int  = 12;
const HTTP_KNOWN_HDR_CONTENT_LENGTH: int = 11;
const HTTP_KNOWN_HDR_STRIDE: int        = 16;  // each HTTP_KNOWN_HEADER = 16 bytes

// ── Zlib constants ────────────────────────────────────────────────────────────

const Z_OK: int              = 0;
const Z_STREAM_END: int      = 1;
const Z_NO_FLUSH: int        = 0;
const Z_FINISH: int          = 4;
const Z_DEFLATED: int        = 8;
const Z_DEFAULT_COMPRESSION: int = -1;
const Z_DEFAULT_STRATEGY: int = 0;
// windowBits 31 = 15 + 16 → gzip output
const Z_GZIP_WINDOW_BITS: int = 31;
const Z_MEM_LEVEL_DEFAULT: int = 8;
// z_stream size on Win64 with MSVC uLong=4: ~88 bytes; use 128 for safety
const Z_STREAM_SIZE: int     = 128;
const ZLIB_VERSION: *char8   = c8"1.2.11".data;

// ── BCrypt constants ──────────────────────────────────────────────────────────

const BCRYPT_ALG_HANDLE_HMAC_FLAG: uint32 = 8;
// BCRYPT_HASH_LENGTH_PROPERTY and SHA256_ALG_ID_WIDE built at call sites via ToWide()
const SHA256_HASH_BYTES: int = 32;

// ── WinHTTP constants ─────────────────────────────────────────────────────────

const WINHTTP_ACCESS_TYPE_DEFAULT_PROXY: uint32 = 0;
const WINHTTP_FLAG_SECURE: uint32               = 0x00800000;
const WINHTTP_ADDREQ_FLAG_ADD: uint32           = 0x20000000;

// ── SQLite3 constants ─────────────────────────────────────────────────────────

const SQLITE_OK: int           = 0;
const SQLITE_ROW: int          = 100;
const SQLITE_DONE: int         = 101;
const SQLITE_INTEGER: int      = 1;
const SQLITE_FLOAT: int        = 2;
const SQLITE_TEXT: int         = 3;
const SQLITE_BLOB: int         = 4;
const SQLITE_NULL: int         = 5;
// SQLITE_TRANSIENT = (sqlite3_destructor_type)(-1) — pointer cast
const SQLITE_TRANSIENT: int    = -1;

// ── SChannel server-side constants ───────────────────────────────────────────

const SECPKG_CRED_INBOUND: uint32           = 1;
// ASC_REQ: REPLAY_DETECT|SEQUENCE_DETECT|CONFIDENTIALITY|ALLOCATE_MEMORY|EXTENDED_ERROR|STREAM
const ASC_REQ_FLAGS: uint32                 = 0x0001811C;

// ── Crypt32 constants ─────────────────────────────────────────────────────────

const PKCS12_NO_PERSIST_KEY: uint32         = 0x00008000;
const CERT_FIND_ANY: uint32                 = 0;
// X509_ASN_ENCODING | PKCS_7_ASN_ENCODING
const CERT_ENCODING_TYPE: uint32            = 0x00010001;

// ── ioctlsocket / select ──────────────────────────────────────────────────────

// Set socket non-blocking: ioctlsocket(sock, FIONBIO, &1)
const FIONBIO: int                          = 0x8004667E;
const WSAEWOULDBLOCK: int                   = 10035;
// fd_set on Win64: 4 bytes fd_count + 4 pad + 64 * 8 bytes fd_array = 520 bytes
const FD_SET_BYTES: int                     = 520;

// ── Response capture (HTTP.sys full routing) ─────────────────────────────────

// Sentinel socket value: when sock == CAPTURE_SOCK, ConnSend writes to a
// CaptureCtx buffer instead of a real socket.
const CAPTURE_SOCK: int                     = -2;

// ── Rate limiting ─────────────────────────────────────────────────────────────

const RATE_PRECISION: int                   = 1000;

// ── Transport mode constants ──────────────────────────────────────────────────

const TRANSPORT_THREAD_POOL: int = 0;
const TRANSPORT_IOCP: int        = 1;
const TRANSPORT_HTTPSYS: int     = 2;

// ── Tuning constants ──────────────────────────────────────────────────────────

const DEFAULT_PORT: uint16            = 8080;
const DEFAULT_WORKERS: int            = 8;
const BACKLOG: int                    = 256;
const RECV_TIMEOUT_MS: uint32         = 5000;
const SEND_TIMEOUT_MS: uint32         = 10000;
const UPSTREAM_TIMEOUT_MS: uint32     = 10000;
const RECV_BUF_SIZE: int              = 8192;
const MAX_FILE_SIZE: int64            = 4194304;
const MAX_HEADERS: int                = 32;
const MAX_PATH_LEN: int               = 512;
const MAX_QUERY_LEN: int              = 1024;
const MAX_HEADER_NAME: int            = 64;
const MAX_HEADER_VALUE: int           = 512;
const BODY_BUF_SIZE: int              = 16384;
const POOL_QUEUE_CAP: int             = 1024;
const PROXY_RELAY_BUF: int            = 8192;
const CONN_POOL_SIZE: int             = 32;
const MAX_KEEPALIVE_REQUESTS: int     = 100;
const MAX_UPSTREAMS: int              = 8;
const DEFAULT_HEALTH_INTERVAL_S: int  = 10;
const IOCP_ACCEPT_POOL: int           = 64;
